# creavy-quote service env (Phase 2a). Copy to .env for local dev (gitignored) OR set as
# Railway service variables for deploy. The loader HARD-FAILS on a missing required var
# (#22) — the service refuses to boot rather than start half-configured.
#
# NO ANTHROPIC_API_KEY here. 2a makes no model call (#34); its presence in a deployed
# environment is a boot error.

# --- required ---
ALLOWED_ORIGIN=https://creavy.netlify.app     # exact production origin (#33). Preview origins
                                              # matching ^https://[a-z0-9-]+--creavy.netlify.app$
                                              # are allowed automatically (https-only).
NODE_ENV=staging                              # development | staging | production

# --- required in production (optional off-prod → in-memory store, non-persistent) ---
DATABASE_URL=postgres://user:pass@host:5432/db   # Railway Postgres plugin provides this

# --- Turnstile (staging OFF; production requires the secret when enabled) ---
TURNSTILE_ENABLED=false
# TURNSTILE_SECRET=0x...                       # required only when TURNSTILE_ENABLED=true

# --- tunables (defaults shown; founder-tunable) ---
PORT=8080
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
DAILY_SCAN_CEILING=200
DAILY_ASSESSMENT_CEILING=50                    # reserved for 2b (no assessments in 2a)
TRUSTED_PROXY_HOPS=1                            # Railway edge = 1 trusted hop
CACHE_TTL_MS=86400000                          # 24 h (#25-A step 7)
